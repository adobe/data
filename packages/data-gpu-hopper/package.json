{
  "name": "data-gpu-hopper",
  "version": "0.9.84",
  "description": "Hopper sample - real-time ECS game rendered as colored cubes via @adobe/data-gpu",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
