{
    "name": "@adobe/data-sync",
    "version": "0.9.84",
    "description": "Multi-user real-time synchronisation for @adobe/data ECS — server, client, and in-process loopback.",
    "type": "module",
    "sideEffects": false,
    "private": false,
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "cp ../../LICENSE . 2>/dev/null || true; tsc -b",
        "clean": "rm -rf dist node_modules",
        "dev": "tsc -b -w --preserveWatchOutput",
        "test": "vitest --run --project=node",
        "test:node": "vitest --run --project=node",
        "typecheck": "tsc -b"
    },
    "dependencies": {
        "@adobe/data": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.8.3",
        "vitest": "^1.6.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    }
}
